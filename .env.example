# ClipDirector AI — environment template
# Copy to .env and fill in values. Never commit .env.

# ── Redis (BullMQ) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AWS S3 (storage backend) ─────────────────────
# In DEV MODE (docker compose default) these talk to MinIO. The app services
# fall back to MINIO_ROOT_USER / MINIO_ROOT_PASSWORD (default minioadmin) if
# AWS_ACCESS_KEY_ID is unset.
#
# In PROD MODE (docker-compose.prod.yml override) these MUST be real AWS keys
# for an IAM user scoped to the two buckets below (e.g. clipdirector-app with
# GetObject/PutObject/DeleteObject only). The prod override clears
# AWS_S3_ENDPOINT and AWS_S3_FORCE_PATH_STYLE automatically.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_INPUT_BUCKET=clipdirector-input
AWS_S3_OUTPUT_BUCKET=clipdirector-output
# AWS_S3_ENDPOINT: leave unset/empty for dev (compose defaults to http://minio:9000).
# Set to a URL to point at a custom MinIO / LocalStack. In prod the override
# file clears this so the SDK uses real AWS endpoints; do not set it yourself.
AWS_S3_ENDPOINT=
# AWS_S3_FORCE_PATH_STYLE is NOT user-overridable from .env. Compose hardcodes
# it to "true" in dev mode (MinIO) and "false" in prod mode (real AWS).

# ── MinIO root credentials (dev only) ────────────
# Used only in DEV MODE by the MinIO container. Do not reuse your AWS keys
# here — previously the compose file borrowed AWS_ACCESS_KEY_ID / _SECRET as
# MinIO root, which made real AWS keys silently double as MinIO root creds.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Claude API ───────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=2000

# ── OpenAI (Whisper transcription) ───────────────
OPENAI_API_KEY=

# ── Render Worker ────────────────────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
RENDER_TEMP_DIR=/tmp/clipdirector
MUSIC_LIBRARY_PATH=/opt/clipdirector/music

# ── API Gateway ──────────────────────────────────
API_PORT=3000
# JWT_SECRET: 32+ chars, random. Generate with: openssl rand -base64 48
JWT_SECRET=
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
DATABASE_FILE=./data/clipdirector.db
MAX_CLIPS_PER_JOB=12
MAX_RAW_FOOTAGE_MINUTES=5
MAX_PROMPT_LENGTH=500
MAX_CLIP_BYTES=524288000

# ── Job TTLs ─────────────────────────────────────
INPUT_BLOB_TTL_HOURS=2
OUTPUT_BLOB_TTL_DAYS=7
JOB_STATUS_TTL_DAYS=7

# ── Logging ──────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
