# ClipDirector AI — environment template
# Copy to .env and fill in values. Never commit .env.

# ── Redis (BullMQ) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AWS S3 (storage backend) ─────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_INPUT_BUCKET=clipdirector-input
AWS_S3_OUTPUT_BUCKET=clipdirector-output
# Optional endpoint override for MinIO / LocalStack in dev
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

# ── Claude API ───────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=2000

# ── OpenAI (Whisper transcription) ───────────────
OPENAI_API_KEY=

# ── Render Worker ────────────────────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
RENDER_TEMP_DIR=/tmp/clipdirector
MUSIC_LIBRARY_PATH=/opt/clipdirector/music

# ── API Gateway ──────────────────────────────────
API_PORT=3000
JWT_SECRET=
MAX_CLIPS_PER_JOB=12
MAX_RAW_FOOTAGE_MINUTES=5
MAX_PROMPT_LENGTH=500

# ── Job TTLs ─────────────────────────────────────
INPUT_BLOB_TTL_HOURS=2
OUTPUT_BLOB_TTL_DAYS=7
JOB_STATUS_TTL_DAYS=7

# ── Logging ──────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
