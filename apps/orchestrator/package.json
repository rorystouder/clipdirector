{
  "name": "@clipdirector/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": { "import": "./dist/index.js" },
    "./processor": { "types": "./dist/processor.d.ts", "import": "./dist/processor.js" },
    "./worker": { "types": "./dist/worker.d.ts", "import": "./dist/worker.js" },
    "./claude": { "types": "./dist/claude/client.d.ts", "import": "./dist/claude/client.js" },
    "./clips/transcriber": { "types": "./dist/clips/transcriber.d.ts", "import": "./dist/clips/transcriber.js" },
    "./clips/downloader": { "types": "./dist/clips/downloader.d.ts", "import": "./dist/clips/downloader.js" },
    "./clips/frame-sampler": { "types": "./dist/clips/frame-sampler.d.ts", "import": "./dist/clips/frame-sampler.js" },
    "./errors": { "types": "./dist/errors.d.ts", "import": "./dist/errors.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@clipdirector/logger": "workspace:*",
    "@clipdirector/queue-client": "workspace:*",
    "@clipdirector/shared-types": "workspace:*",
    "@clipdirector/storage-client": "workspace:*",
    "bullmq": "^5.8.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.4.0",
    "openai": "^4.55.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/uuid": "^9.0.8",
    "testcontainers": "^11.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
