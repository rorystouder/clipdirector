{
  "name": "@clipdirector/render-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": { "import": "./dist/index.js" },
    "./processor": { "types": "./dist/processor.d.ts", "import": "./dist/processor.js" },
    "./worker": { "types": "./dist/worker.d.ts", "import": "./dist/worker.js" },
    "./music": { "types": "./dist/music/selector.d.ts", "import": "./dist/music/selector.js" },
    "./ffmpeg/runner": { "types": "./dist/ffmpeg/runner.d.ts", "import": "./dist/ffmpeg/runner.js" },
    "./errors": { "types": "./dist/errors.d.ts", "import": "./dist/errors.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@clipdirector/logger": "workspace:*",
    "@clipdirector/queue-client": "workspace:*",
    "@clipdirector/shared-types": "workspace:*",
    "@clipdirector/storage-client": "workspace:*",
    "bullmq": "^5.8.0",
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "testcontainers": "^11.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
